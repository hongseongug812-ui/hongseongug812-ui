{% macro render_row(items) -%}
{% for item in items %}{% if item.icon %}<a href="{{ item.url }}"><img src="https://skillicons.dev/icons?i={{ item.icon }}&theme=dark" alt="{{ item.name }}" title="{{ item.name }}" height="28"></a>{% else %}<img src="https://img.shields.io/badge/-{{ item.name | urlencode }}-333333?style=flat-square" alt="{{ item.name }}" title="{{ item.name }}">{% endif %}{% if not loop.last %} {% endif %}{% endfor %}
{%- endmacro %}
<div align="center">

<img src="{{ render.header_svg_path }}" width="100%" alt="{{ profile.name }} 프로필 헤더">

<br>

{% if profile.introduction %}<p><b>{{ profile.introduction }}</b></p>{% endif %}

<sub>공개 저장소를 자동으로 분석 · 매시간 갱신</sub>

<a href="https://github.com/{{ profile.github_username }}?tab=repositories">저장소 보기</a>
{% if profile.email %} · <a href="mailto:{{ profile.email }}">이메일</a>{% endif %}
{% if profile.blog_url %} · <a href="{{ profile.blog_url }}">블로그</a>{% endif %}

</div>

<br>

## 소개

{% if profile.story %}
{{ profile.story }}
{% endif %}

{% if profile.affiliation or profile.interests or profile.certifications or profile.strengths or profile.current_focus %}
<table>
  {% if profile.affiliation %}<tr><td><b>소속</b></td><td>{{ profile.affiliation }}</td></tr>{% endif %}
  {% if profile.interests %}<tr><td><b>관심 분야</b></td><td>{{ profile.interests | join(' · ') }}</td></tr>{% endif %}
  {% if profile.certifications %}<tr><td><b>자격증</b></td><td>{{ profile.certifications | join(' · ') }}</td></tr>{% endif %}
  {% if profile.strengths %}<tr><td><b>강점</b></td><td><ul>{% for item in profile.strengths %}<li>{{ item }}</li>{% endfor %}</ul></td></tr>{% endif %}
  {% if profile.current_focus %}<tr><td><b>현재 집중하는 것</b></td><td><ul>{% for item in profile.current_focus %}<li>{{ item }}</li>{% endfor %}</ul></td></tr>{% endif %}
</table>
{% endif %}

{% set has_stacks = stack_rows.ai_cloud or stack_rows.back_end or stack_rows.front_end or stack_rows.database or stack_rows.development_tools %}
{% if has_stacks %}
<br>

## 기술 스택

<table>
  {% if stack_rows.ai_cloud %}<tr><td><b>AI & 클라우드</b></td><td>{{ render_row(stack_rows.ai_cloud) }}</td></tr>{% endif %}
  {% if stack_rows.back_end %}<tr><td><b>백엔드</b></td><td>{{ render_row(stack_rows.back_end) }}</td></tr>{% endif %}
  {% if stack_rows.front_end %}<tr><td><b>프론트엔드</b></td><td>{{ render_row(stack_rows.front_end) }}</td></tr>{% endif %}
  {% if stack_rows.database %}<tr><td><b>데이터베이스</b></td><td>{{ render_row(stack_rows.database) }}</td></tr>{% endif %}
  {% if stack_rows.development_tools %}<tr><td><b>개발 도구</b></td><td>{{ render_row(stack_rows.development_tools) }}</td></tr>{% endif %}
</table>
{% endif %}

<br>

## 언어 사용 비율

<div align="center">
  <img src="{{ render.language_svg_path }}" width="100%" alt="대표 프로젝트의 언어 분포">
</div>

<br>

## 대표 프로젝트

<table>
{% for row in repositories | batch(2) %}
  <tr>
  {% for repo in row %}
    <td width="50%" valign="top">
      <h3><a href="{{ repo.url }}">{{ repo.name }}</a></h3>
      <p>{{ repo.summary }}</p>
      <p>
        {% if repo.primary_language %}<img src="https://img.shields.io/badge/-{{ repo.primary_language.name | urlencode }}-333333?style=flat-square" alt="{{ repo.primary_language.name }}">{% endif %}
        <img src="https://img.shields.io/github/stars/{{ repo.full_name }}?style=flat-square&label=%E2%98%85&color={{ render.theme_color }}&labelColor=333333" alt="stars">
        <img src="https://img.shields.io/github/last-commit/{{ repo.full_name }}?style=flat-square&label=updated&color={{ render.theme_color }}&labelColor=333333" alt="last commit">
      </p>
      <p><a href="{{ repo.url }}"><b>저장소 보기 →</b></a></p>
    </td>
  {% endfor %}
  {% if row | length == 1 %}<td width="50%"></td>{% endif %}
  </tr>
{% endfor %}
</table>

{% if activities %}
<br>

## 활동 내역

{% for group in activities %}
### {{ group.year }}

{% for item in group['items'] %}
- **{{ item.title }}**{% if item.period %} <sub>{{ item.period }}</sub>{% endif %}{% if item.description %} — {{ item.description }}{% endif +%}
{% endfor %}

{% endfor %}
{% endif %}

---

<div align="center"><sub>공개 저장소를 기반으로 자동 큐레이션 · 매시간 갱신</sub></div>
